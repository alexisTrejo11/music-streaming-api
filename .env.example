# Copy to .env and adjust values.
# Loaded by python-decouple (Django) and Docker Compose.
#
# Usage:
#   Local (no Docker):  cp .env.example .env  →  python manage.py runserver
#   Docker local stack: cp .env.example .env  →  see docker/README.md
#   Docker production:  cp .env.example .env  →  set DATABASE_URL + production values

# =============================================================================
# Django core
# =============================================================================

# config.settings.development → SQLite, debug toolbar (default for local dev)
# config.settings.production  → set in docker-compose.prod.yml
# config.settings.docker      → set in docker-compose.local.yml
DJANGO_SETTINGS_MODULE=config.settings.development

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Production only (docker-compose.prod.yml)
# Not used for local dev (SQLite) or Docker local stack (compose sets DATABASE_URL).
# =============================================================================

# DATABASE_URL=postgresql://user:password@your-db-host.rds.amazonaws.com:5432/dbname
# SECURE_SSL_REDIRECT=False

# =============================================================================
# Docker Compose — host port mappings only
# Internal service URLs (postgres, redis) are set in docker-compose.local.yml.
# =============================================================================

WEB_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
